		<Item class="Script" referent="RBXE3C3A6BB1EB549699CAC1DFE5AE0C241">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--[[
	BEHAVIOR TREE EDITOR V4.1
	
	Originally by tyridge77: https://devforum.roblox.com/t/btrees-visual-editor-v2-0/461015
	Forked and improved by defaultio

	Improvements/changes:
		- Nodes are easy to add via the NodeInfo module
		- Support for nodes with parameters
		- There is an explicit root node, so you can change the tree root without needing to destroy a bunch of nodes until the autoselected root happens to be the one you want.
		- Node colors by category (composite/decorator/leaf/root) rather than by individual node type. I think this is easier to read at a glance.
		- When you drag a node around, all descendant nodes will move with it
		- After dragging a node, it and its siblings index order is automatically resorted based on X position
		- Behavior tree folders can be created anywhere, instead of locked to a single directory for all of them.
		- The node info in the help window is dynamically populated from the list of node types in the NodeInfo module.
		- Random weight inputs will round up decimal inputs, as these aren’t supported with the random weighting implementation
		- Pretty bezier connector lines 
			
			
	Changes by tyridge77(November 23rd, 2020)
		
		- Changed how trees are created and ran
			- Trees are now decoupled from instances, acting more as pure functions not necessarily attached to any specific object
			- Trees are created with BehaviorTreeCreator:Create(treefolder). If a tree is already created for that folder it will return that tree
			- Trees are now run using Tree:Run(object,...)
			- object must be a table 
			
		- Added new tree method, Tree:Abort()
			- Calls finish() on the running task of the tree, and sets the tree index back to 1
			- Should be used if you want to cancel out of a tree to swap to another(for instance in the case of a state change)
			
		- Added Blackboards.
			- Literally just a table that trees can read from and write to via tasks
			- Injected into the object passed into a tree via Tree:Run(object), if it doesn't already exist
			- Commonly used to see if a value is set or not in order to dictate the flow of relevant logic in a tree
			
			- Shared Blackboards are also a thing. You shouldn't write to these in a tree, but they are useful for reading shared states(global stuff, player stuff, are the lights off in a scene)
				- To register a Shared Blackboard use BehaviorTreeCreator:RegisterSharedBlackboard(name,table)
	
		- Added new Leaf node, Blackboard Query
			- These are used to perform fast and simple comparisons on a specific key in a blackboard
			- For instance, if you wanted a sequence to execute only if the entity's "LowHealth" state was set to true, or if a world's "NightTime" state was set to true(Shared Blackboard)
			- You can do this with tasks , but it's a bit faster if you only need to perform a simple boolean or nil check
			
			- You can only read from a blackboard using this node. Behavior Trees aren't meant to be visual scripting - just a way to carry out plans
			
			- Parameters:
				
				- Board: string that defaults to Entity if no value is specified. 
					- Entity will reference the object's blackboard passed into the tree via tree:Run(object)
					- If a value is given, say "WorldStates", it will attempt to grab the Shared Blackboard to use with the same name. You can register these via BehaviorTreeCreator:RegisterSharedBlackboard(name,table)

				- Key: the string index of the key you're trying to query(for instance, "LowHealth")
				- Type: string which specifies what kind of query you're trying to perform.
					- You can choose true,false,set,or unset to perform boolean/nil checks. Alternatively you can specify a string of your choice to perform a string comparison
		
		- Added new composite node, While
			- Only accepts two children, a condition(1st child), and an action(2nd child)
			- Repeats until either
				- condition returns fail, wherein the node itself returns fail
				- action returns success, wherein the node itself returns success
			
			- Used for processing stacks of items
				- Say you want an NPC to create a stack of nearby doors, then try to enter each door until there are no doors left to try, or the NPC got through a door.
				- If the NPC got through a door successfully, the node would return success. Otherwise, if there were no doors that were able to be entered, the node will return fail
				- Example pic: https://cdn.discordapp.com/attachments/711758878995513364/783523673704628294/unknown.png
				
		- Added comment nodes
			- To edit a comment click the edit button on top of the comment node
			- Two other toggle buttons are TextScaled and Text X Alignment
			
		- Added live tree debugging to assist in figuring out what your tree is doing ! : ) 
			To use , join a game and click on the debug button under the plugin buttons
			
			- This will open a window of trees which have ran at least once. 
			- Each debuggable tree in the window will have its name set to the object's table name, unless the object has an index called name or Name, which it will then use
			
			- To debug a tree, click on the debug button.
				- This will open up the tree similar to the editor, only you can't edit anything
				- The currently running task/tree will be higlighted in yellow, with a yellow path dictating how it got there from the root
			
			
		- Misc/QOL Updates and Fixes
		
			- Fixed issue where repeater node didn't function properly
			
			- Added some stuff to BehaviorTree3 just to support tree debugging
			
			- You can no longer edit trees while a game is running
			
			- Index resorting happens automatically when you add a new node, before it only happened when you released drag
			
			- Nodes with more than one parameter are now scaled up a bit more by default
			
			- The add node window is now properly clamped to the extents of your screen

	Changes by MetaProx(April 8th, 2022):

		- External Nodes
		
			- Added some cool new External nodes that allow for the ability to connect to task modules outside
			
	Changes by OssieNomae (May 16th, 2026):
	
		- Added the ability to modify the Task Template
		
		- Added support for PascalCase for start, finish & run (Start, Finish & Run) in tasks
			
--]]


if not plugin then
	return
end

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local CHS = game:GetService("ChangeHistoryService")
local Selection = game:GetService("Selection")

local Toolbar = plugin:CreateToolbar("BTrees")
local PluginMouse = plugin:GetMouse()
local Editor = require(script.Editor)

local TREE_TAG = "_BTree"

local folder = script.Parent

local Maid = require(folder.Utility.Maid)
local TaskTemplate = require("@self/TaskTemplate")
TaskTemplate.SetPlugin(plugin)

local NodeTemplate = folder.TreeTemplate.Nodes.NodeTemplate:clone()
folder.TreeTemplate.Nodes.NodeTemplate:Destroy()
local TreeTemplate = folder.TreeTemplate:clone()

local TaskTemplateSource


local function SetCHSEnabled(bool)
	CHS:SetEnabled(bool)
end

local TreesFolder


local function CreateButton(...)
	local button = Toolbar:CreateButton(...)
	button.ClickableWhenViewportHidden=true
	return button
end

local Create = CreateButton("Create","Create a new tree","http://www.roblox.com/asset/?id=4672182214")
local Debug = CreateButton("Debug","Debug a currently running tree","http://www.roblox.com/asset/?id=4672182214") -- Tree debugger
local Template = CreateButton("Template","Modify task template","http://www.roblox.com/asset/?id=4672182214")

local RunningGame = RunService:IsRunning()
Create.Enabled = not RunningGame
Template.Enabled = not RunningGame
Debug.Enabled = RunningGame

local Exit = CreateButton("Close","Close the editor","")
Exit.Enabled=false

TaskTemplate.InitButton(Template)
Editor:Init(Exit,PluginMouse,plugin)



-- Tree objects will be the core of BehaviorTrees
-- Tree objects have nodes which various types, which are used to control the flow of logic and have attached module functions

local TreeObject = {}
local TreeObjects = {}
local TreeMap = {}
TreeObject.__index=TreeObject

local TreeNode = {}
TreeNode.__index=TreeNode

local NodeInfo = require(script.NodeInfo)


function TreeNode.new(tree,folder,nodeType,linkedfrom,initParams)
	local self = setmetatable({},TreeNode)
	self.tree=tree
	self.type=nodeType
	self.nodeInfo = NodeInfo.Dictionary[nodeType]
	self.category = NodeInfo.Dictionary[nodeType].Type
	
	local UpdateSorts = folder == nil
	
	if not linkedfrom then
		if folder then
			linkedfrom = folder:FindFirstChild("Link")
		end
	end
	
	if not folder then 
		SetCHSEnabled(false)
		folder = NodeTemplate:clone()
		folder.Type.Value=nodeType
		
		self.folder = folder

		self:SetName("Node"..#self.tree.Nodes+1)
		SetCHSEnabled(true)
	else
		self.folder=folder
		self:SetName(folder.Name)
		local weight = folder:FindFirstChild("Weight")
		if weight then
			self.Weight=weight.Value
		end
	end
	
	if initParams then
		for key, val in pairs(initParams) do
			self:SetParameter(key, val)
		end
	end
	
	local Outputs = folder.Outputs
	self.Outputs=Outputs
	
	self.Index = folder.Parameters.Index
	
	-- ModuleScript setup for Tasks
	if nodeType == "Task" then
		if not linkedfrom then
			local taskModule = folder:FindFirstChildWhichIsA("ModuleScript")
			if not taskModule then
				taskModule = Instance.new("ModuleScript",folder)
				taskModule.Source = TaskTemplate.GetTemplate()
			end
			taskModule.Name=folder.Name
			folder:GetPropertyChangedSignal("Name"):connect(function()
				taskModule.Name=folder.Name
			end)
			self.TaskModule=taskModule
		else
			local linkobj = folder:FindFirstChild("Link")
			if not linkobj then
				linkobj = Instance.new("ObjectValue",folder)
				linkobj.Name="Link"
				linkobj.Value=linkedfrom.folder
			end
			self.Link=linkobj.Value
		end
	end
	
	if nodeType == "External Task" then
		task.spawn(function()
			local sourceLink = folder.Parameters:WaitForChild("Source")
			self.SourceLink = sourceLink
		end)
	end
	
	folder.Parent=tree.folder.Nodes
	
	folder.AncestryChanged:connect(function(_,par)
		if not par then
			self:Dispose()
		end
	end)
		
	Editor:NodeAdded(self)
		
	if UpdateSorts then
		self:UpdateOutputSorts()
	end
	
	return self
end
function TreeNode:SetWeight(n)
	local weightval = self.folder:FindFirstChild("Weight")
	if not weightval then
		weightval = Instance.new("NumberValue",self.folder)
		weightval.Name="Weight"
	end
	weightval.Value=n
	self.Weight=n
end
function TreeNode:SetParameter(key, val)
	local paramVal = self.folder.Parameters:FindFirstChild(key)
	if not paramVal then
		local t = typeof(val)
		if t == "number" then
			paramVal = Instance.new("NumberValue",self.folder.Parameters)
		elseif val == nil or t == "Instance" then -- Funny hack 2
			paramVal = Instance.new("ObjectValue",self.folder.Parameters)
		elseif t == "string" then
			paramVal = Instance.new("StringValue",self.folder.Parameters)
		elseif t == "boolean" then
			paramVal = Instance.new("BoolValue",self.folder.Parameters)
		else
			error("Unknown parameter type "..tostring(key)..": "..tostring(t))
		end
		paramVal.Name=key
	end
	paramVal.Value=val
	if key == "Index" then
		self:AttemptManualResort(val)
	end
end
function TreeNode:GetParameter(key)
	local paramVal = self.folder.Parameters:FindFirstChild(key)
	if paramVal then
		return paramVal.Value
	end
end
function TreeNode:SetRoot(removeoutputs)
	--print("Set Root to ",self.folder)
	self:SetName("Root")
	self.tree.Root=self
	if self.GuiNode then
		self.GuiNode:SetRoot()
	end
	local Input = self.Input
	if Input then
		self.Input:RemoveOutput(self)
	end
	if removeoutputs then
		local Outputs = self:GetOutputs()
		for i = 1,#Outputs do
			local value = Outputs[i]
			if value then
				local folder = value.Value
				if folder then
					local node = self.tree:GetNodeByFolder(folder)
					if node then
						self:RemoveOutput(node)
					end
				end
			end
		end
	end
	self:UpdateOutputSorts()
end
function TreeNode:GetCanManualResort(text)
	local number = tonumber(text)
	if not number then
		return false,"Not a number"
	end
	if not self.OutputSort then
		return false,"No output sort"
	end
	if number < 1 then
		return false,"Num < 1: "..number
	end
	if number == self.OutputSort then
		return false,"Already outputsort"
	end
	local folder = self.Input:GetOutputs()[number]
	if not folder then
		return false,"No folder for input"
	end
	if not self.Input:GetOutputs()[self.OutputSort] then
		return false,"No folder for current index"
	end
	if number > #self.Input:GetOutputs() then
		return false,"> Num Outputs"
	end
	return number
end
function TreeNode:AttemptManualResort(text)
	local input = self.Input
	local passed
	if input then
		local number,er = self:GetCanManualResort(text)
		if number then
			local folder = input:GetOutputs()[number]
			local mine = input:GetOutputs()[self.OutputSort]
			if folder then
				mine.Name=text
				folder.Name=tostring(self.OutputSort)
				
				input:UpdateOutputSorts()
				return
			end
		else
			warn(er)
		end
	end
	if self.OutputSort then
		self:UpdateSort(self.OutputSort)
	end
end
function TreeNode:GetOutputs()
	local list = {}
	local children = self.Outputs:GetChildren()
	for i = 1,#children do
		local value = children[i]
		table.insert(list,value)
	end
	table.sort(list,function(a,b)
		return tonumber(a.Name) < tonumber(b.Name)
	end)
	return list
end
function TreeNode:GetOutput(outputFolder)
	local Outputs = self:GetOutputs()
	for i = 1,#Outputs do
		local value = Outputs[i]
		if value then
			local folder = value.Value
			if folder == outputFolder then
				return value
			end
		end
	end
end
function TreeNode:UpdateSort(i)
	self.OutputSort=i
	if self.GuiNode then
		self.GuiNode:UpdateSort(i)
	end
end
function TreeNode:UpdateOutputSorts()
	local outputs = self:GetOutputs()
	for i = 1,#outputs do
		local output = outputs[i]
		if output then
			local folder = output.Value
			local node = self.tree:GetNodeByFolder(folder)
			if node then
				node:UpdateSort(i)
			end
		end
	end
end
function TreeNode:CreateOutput(folder)
	local outputNode = self.tree:GetNodeByFolder(folder)
	if self.nodeInfo.MaxOutputs then
		local outputs = self:GetOutputs()
		for i = 1, #outputs - self.nodeInfo.MaxOutputs + 1 do
			local folder = outputs[i].Value
			if folder then
				local node = self.tree:GetNodeByFolder(folder)
				if node then
					self:RemoveOutput(node)
					if node.GuiNode and self.GuiNode then
						node.GuiNode:ClearLine(self.GuiNode)
					end
				end
			end
		end	
	end
	if outputNode then
		local input = outputNode.Input
		if input then
			input:RemoveOutput(outputNode)
		end
		local value = Instance.new("ObjectValue")
		value.Value=folder
		local index = #self.Outputs:GetChildren()+1
		value.Name = index
		SetCHSEnabled(false)
		value.Parent=self.Outputs
		SetCHSEnabled(true)
		self:UpdateOutputSorts()
		self:SetOutput(folder)
	else
		warn("No output node!")
	end
end
function TreeNode:SetOutput(folder)
	local node = self.tree:GetNodeByFolder(folder)
	if node then
		node.Input=self
		if node.GuiNode then
			node.GuiNode:CreateLineConnection()
		end
	end
end
function TreeNode:RemoveOutput(node)
	local outputFolder = node.folder
	local value = self:GetOutput(outputFolder)
	if value then
		value:Destroy()
	end
	local outputs = self:GetOutputs()
	for i = 1,#outputs do
		local output = outputs[i]
		output.Name=i
	end
	self:UpdateOutputSorts()
	node.Input=nil
	node:UpdateSort(nil)
	if self.GuiNode and node.GuiNode then
		self.GuiNode:ClearLine(node.GuiNode)
	end
end

function TreeNode:GetTask()
	if self.TaskModule then
		return self.TaskModule
	elseif self.Link then
		local node = self.tree:GetNodeByFolder(self.Link)
		if node then
			return node:GetTask()
		end
	elseif self.SourceLink then
		return self.SourceLink.Value
	end
end

function TreeNode:OpenTask()
	if self:GetTask() then
		plugin:OpenScript(self:GetTask())
	else
		warn("Could not find task source!")
	end
end
function TreeNode:SetName(s)
	self.name=s
	self.folder.Name=s
	if self.GuiNode then
		self.GuiNode:SetName(s)
	end
end

function TreeNode:Dispose()
	if self.Disposed then
		return
	end
	self.Disposed=true
	local index = table.find(self.tree.Nodes,self)
	if index then
		table.remove(self.tree.Nodes,index)
	end
	self.tree.NodesMap[self.folder]=nil
	for i = 1,#self.tree.Nodes do
		local thisnode = self.tree.Nodes[i]
		if thisnode then
			if thisnode.name:match("Node%d+") then
				thisnode:SetName("Node"..i)
			end
			thisnode.Index.Value=i
		end		
	end
	
	if self.GuiNode then
		self.GuiNode:Dispose()
	end

	-- Remove connections
	if self.Input then
		self.Input:RemoveOutput(self)
	end
		
	local outputs = self:GetOutputs()
	for i = 1,#outputs do
		local value = outputs[i]
		if value then
			local folder = value.Value
			local node = self.tree:GetNodeByFolder(folder)
			if node then
				node.Input=nil
				node:UpdateSort(nil)
			end
		end
	end
	pcall(function() self.folder:Destroy() end)
	
	if self.tree.Root == self then
		-- Set new root
		local newRoot = self.tree:GetFirstRootNode()
		if newRoot then
			newRoot:SetRoot(true)
		end
	end	
end
function TreeObject.new(folder)
	local self = setmetatable({},TreeObject)
	
	if TreeMap[folder] then
		return
	end
	
	self.Nodes={}
	self.NodesMap={}
	
	
	if not folder then
		folder = TreeTemplate:clone()
		folder.Parent = game.Selection:Get()[1] --TreesFolder.Trees
		folder.Name = "NewTree"..#TreeObjects+1
		CollectionService:AddTag(folder, TREE_TAG)
	end
	
	self.folder=folder
		
	local ancestry_changed = folder.AncestryChanged:connect(function(_,par)
		if not par then
			self:Dispose()
		end	
	end)
	
	
	folder:GetPropertyChangedSignal("Name"):connect(function()
		if self.Root then
			if self.Root.GuiNode then
				self.Root.GuiNode:SetName(folder.Name)
			end
		end	
	end)
	
	-- Instantiate nodes from folders
	
	local nodesChildren = self.folder.Nodes:GetChildren()
	
	
	for i = 1,#nodesChildren do
		local node = nodesChildren[i]
		self:CreateNode(node,node.Type.Value)
	end
	--
	
	
	local Root = self:GetRootNode()
	if Root then
		Root:SetRoot(false)
	end
	
	
	for i = 1,#self.Nodes do
		local node = self.Nodes[i]
		if node then
			local OutputsList = node:GetOutputs()
			for i = 1,#OutputsList do
				local folder = OutputsList[i].Value
				if not node:GetOutput(folder) then
					node:CreateOutput(folder)
				else
					node:SetOutput(folder)
				end
				node:UpdateOutputSorts()
			end
		end	
	end
		
	-- Create debug paths for the debugger
	self.DebugPaths = {}
	if RunningGame then
		for i,node in pairs(self.Nodes) do
			if (node.type == "Task" or node.type == "Tree") and node.Input then
				local input = node
				
				local path = {node}
				
				while true do
					input = input.Input
					if not input then
						break
					else
						table.insert(path,input)
					end
				end
				
				if path[#path] == Root then
					self.DebugPaths[node] = path
				end
			end
		end
	end
	self.DebugReady = true
	--
	
	TreeMap[folder]=self
	table.insert(TreeObjects,self)
	return self
end

function TreeObject:GetFirstRootNode()
	local list = {}
	for i = 1,#self.Nodes do
		local node = self.Nodes[i]
		if node and node.type == "Root" then
			table.insert(list,node)
		end
	end
	table.sort(list,function(a,b) return a.Index.Value < b.Index.Value end)
	return list[1]
end
function TreeObject:GetRootNode()
	local nodesFolders = self.folder.Nodes:GetChildren()
	for i = 1,#nodesFolders do
		local node = nodesFolders[i]
		if node then
			if node.Name == "Root" then
				return self:GetNodeByFolder(node)
			end
		end
	end
end
function TreeObject:GetNodeByFolder(folder)
	if not folder then
		return
	end
	return self.NodesMap[folder] or self:CreateNode(folder,folder.Type.Value)
end
function TreeObject:CreateNode(folder,nodeType,linkedFrom,initParams)
	if self.NodesMap[folder] then 
		return
	end
	
	if folder then
		--print("CREATING NODE: ",folder:GetFullName(),nodeType)
	end	
	
	local newNode = TreeNode.new(self,folder,nodeType,linkedFrom,initParams)
	
	local newIndex = #self.Nodes+1
	newNode.Index.Value=newIndex
	table.insert(self.Nodes,newNode)
	self.NodesMap[newNode.folder]=newNode
	if nodeType == "Root" and not self:GetRootNode() then
		newNode:SetRoot(true)
	end
	
	return newNode
end
function TreeObject:CreateLinkedNode(fromnode)
	local nodeType = fromnode.type
	local newNode = self:CreateNode(nil,nodeType,fromnode)
	if fromnode.name then newNode:SetName(fromnode.name) end
	return newNode
end

function TreeObject:Edit()
	Editor:Open(self,true)
end
function TreeObject:Debug(nodeval)
	Editor.DebugNode = nodeval
	Editor:Open(self)
end

function TreeObject:Dispose()
	
	if Editor.Editing == self then
		Editor:Close()
	end
	
	local index = table.find(TreeObjects,self)
	if index then
		table.remove(TreeObjects,index)
	end
	TreeMap[self.folder]=nil
end



for _, treeFolder in pairs(CollectionService:GetTagged(TREE_TAG)) do
	TreeObject.new(treeFolder)
end


local function CreateNewTree()
	if #game.Selection:Get() ~= 1 then
		warn("Select an instance to parent new Tree to")
		return
	end
	local newTree = TreeObject.new()
	newTree:CreateNode(nil, "Root")
	newTree:Edit()
	Selection:Set({newTree.folder})
end

Create.Click:connect(function()
	CreateNewTree()
	Create:SetActive(false)
end)


-- TREE DEBUGGING

local DebugMaid = Maid.new()
local DebugNodes = {}
local DebugWindowActive = false

if CoreGui:FindFirstChild("BTDebug") then
	CoreGui.BTDebug:Destroy()
end
local DebugGui = script.BTDebug:clone()


local DebugClose = DebugGui.DebugWindow.Header.Close



local Node = DebugGui:FindFirstChild("Node",true)
local NodeFrame = Node.Parent
local NodeTemplate = Node:clone()
Node:Destroy()


DebugGui.Parent = CoreGui


local function CanDebug()
	return CollectionService:GetTagged("_btRunningTrees")[1] ~= nil
end
local function CleanDebug()
	table.clear(DebugNodes)
	DebugMaid:Cleanup()
end
local function CloseDebugWindow()
	CleanDebug()
	DebugWindowActive = false
	DebugGui.Enabled = false
end
local function OpenDebugWindow()	
	if CanDebug() then
		DebugGui.Enabled = true
		DebugWindowActive = true
		local LastDebugRefresh
		
		local RunningTrees = CollectionService:GetTagged("_btRunningTrees")[1]
		
		DebugMaid:AddTask(
			RunService.Heartbeat:connect(function()
				local timeNow = os.clock()
				if timeNow - (LastDebugRefresh or 0) > 1 then
					LastDebugRefresh = timeNow
					
					-- Iterate through active trees
					
					for i,tree in pairs(RunningTrees:GetChildren()) do
						
						for i,entity in pairs(tree:GetChildren()) do
							if not DebugNodes[entity] then
								
								local treefolder = entity:FindFirstChild("TreeFolder").Value
								
								local mapped = TreeMap[treefolder]
								if mapped and mapped.DebugReady then
									local nameval = entity:FindFirstChild("Name")
									local name = nameval and nameval.Value or entity.Name
									local title = tree.Name
									local newNode = NodeTemplate:clone()
									newNode.Parent = NodeFrame
									
									local button = newNode.Debug
									local uiscale = button.DebugScale
									local DebugGradient = button.Background.BG.rounded.DebugGradient
									
									
									local node = entity:FindFirstChild("Node")
									
									DebugMaid:AddTask({
										button.MouseEnter:connect(function()
											uiscale.Scale = 1.05
											DebugGradient.Transparency = NumberSequence.new(0)
										end),
										button.MouseLeave:connect(function()
											uiscale.Scale = 1
											DebugGradient.Transparency = NumberSequence.new(0.8)
										end),
										button.MouseButton1Down:connect(function() 
											
											local Tree = TreeMap[treefolder]
											if Tree and node then
												Tree:Debug(node)
											end
										end)
									})
									
									newNode:FindFirstChild("Title",true).Text = name
									newNode:FindFirstChild("Tree",true).Text = title
									
									DebugMaid:AddTask(newNode)
									
									DebugNodes[entity] = true
								end
							end
						end
					end	
				end
			end)
		)
	end
end
local function ToggleDebug()	
	if not DebugWindowActive then
		OpenDebugWindow()
	else
		CloseDebugWindow()
	end
end

DebugClose.MouseEnter:connect(function()
	DebugClose.UIScale.Scale=1.05
	DebugClose.Icon.ImageColor3=Color3.new(1,1,1)
end)
DebugClose.MouseLeave:connect(function()
	DebugClose.UIScale.Scale=1
	DebugClose.Icon.ImageColor3=Color3.fromRGB(152,52,52)
end)
DebugClose.MouseButton1Down:connect(function()
	CloseDebugWindow()
end)


Debug.Click:connect(function()
	ToggleDebug()
	Debug:SetActive(false)
end)

--

if not RunningGame then
	Selection.SelectionChanged:connect(function()
		local get = Selection:Get()
		local closing = true
		if #get == 1 then
			local selected = get[1]
			if selected then
				local Tree = TreeMap[selected]
				if Tree then
					closing=false
					if Editor.Editing ~= Tree then
						SetCHSEnabled(false)
						Editor:Close()
					end
					Tree:Edit()
					SetCHSEnabled(true)
				end
			end
		end	
		if closing then
			if Editor.Editing then
				SetCHSEnabled(false)
			end
			Editor:Close()
			SetCHSEnabled(true)
		end
	end)
end

Exit.Click:connect(function()
	Editor:Close()
	Selection:Set({})
	Exit:SetActive(false)
end)

