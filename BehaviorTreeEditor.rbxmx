				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Editor = {
	GuiNodes={},
	Locked = false -- Oh boy hope I'm doing this right - Meta
}


local CoreGui = game:GetService("CoreGui")

local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local ContentProvider = game:GetService("ContentProvider")
local Selection = game:GetService("Selection")
local ContextActionService = game:GetService("ContextActionService")
local TextService = game:GetService("TextService")
local PluginExit
local PluginMouse
local PluginMouseIcon
local plugin

local ZOOMSPEED = 0.1
local ZOOM_MIN = 0.1
local ZOOM_MAX = 2

local Connectors = require(script.Connectors)
local NodeInfo = require(script.Parent.NodeInfo)


local NodeTemplate
local CommentTemplate

local Tooltip

local Keybinds

function Editor:SaveKeybinds()
	plugin:SetSetting("Binds",Keybinds)
end

local defaultBinds = {
	Delete=Enum.KeyCode.F.Name,
	Duplicate=Enum.KeyCode.G.Name,
	LinkedDuplicate=Enum.KeyCode.J.Name,
	Edit=Enum.KeyCode.K.Name
}
		
		
function Editor:GetKeybinds()
	local GotBinds = plugin:GetSetting("Binds")
	if Keybinds then
		return Keybinds
	elseif GotBinds then
		return GotBinds
	else
		Keybinds=defaultBinds
		self:SaveKeybinds()
		return Keybinds
	end
end



local function PercentBetween(i,n1,n2)
	return (n2 - n1) == 0 and 1 or math.clamp((i - n1) / (n2 - n1), 0, 1)
end
local function lerp(n,g,t)
	return n+(g-n)*t
end

local function TooltipDisplay(button,txt)
	Tooltip.Text=txt
	
	local mouseX = button.AbsolutePosition.x+button.AbsoluteSize.x
	local mouseY = button.AbsolutePosition.y+button.AbsoluteSize.x
	Tooltip.Position=UDim2.new(0,mouseX,0,mouseY)
	Tooltip.Visible=true
end

local GuiNode = {}
GuiNode.__index=GuiNode


function GuiNode.new(node)
	local self = setmetatable({},GuiNode)
	
	if Editor.GuiNodes[node] then
		return
	end
		
	self.Active=true
	
	node.GuiNode=self
	
	self.node=node
	
	if not node.folder.Parent then
		return
	end
	
	local nodeType = self.node.type
	self.nodeType = nodeType
	self.nodeInfo = NodeInfo.Dictionary[nodeType]
	
	self.parameters = self.nodeInfo.Parameters or {}
	self.parameters.Index = {Default = 1, Input = function(text) if tonumber(text) then return math.floor(tonumber(text)) end end}
	
	local isTask = nodeType == "Task"
	self.IsLinked = self.node.Link ~= nil
	self.isTask = isTask
	
	local isExternalTask = nodeType == "External Task"
	self.isExternalTask = isExternalTask
	
	
	self.isComment = self.nodeType == "Comment"
		

	local gui = (self.isComment and CommentTemplate or NodeTemplate):clone()
	
	if not self.isComment then
		if self.nodeInfo.MaxOutputs == 0 then
			gui.OutputButton:Destroy()
			gui.OutputOver:Destroy()
		end
		if nodeType == "Root" then
			gui.InputButton:Destroy()
			gui.InputOver:Destroy()
		end
	end
	
	gui.Parent=Editor.Workspace
	
	self.gui = gui
	
	for i,v in pairs(gui:GetDescendants()) do
		self[v.Name]=v
	end
	
	if self.isComment then
		
		local CommentBox = self.CommentBox
		local CommentLabel = self.CommentLabel
		
		local CommentText = self.node:GetParameter("CommentText")
		if CommentText == nil then
			CommentText = ""
			self.node:SetParameter("CommentText","")
		end
		
		local TextScaled = self.node:GetParameter("TextScaled")
		if TextScaled == nil then
			TextScaled = false
			self.node:SetParameter("TextScaled",false)
		end
		
		local XAlignment = self.node:GetParameter("CenterAligned")
		if XAlignment == nil then
			XAlignment = false
			self.node:SetParameter("CenterAligned",false)
		end
		
		self.EditButton.Visible = Editor.Editing
		self.TextScaledButton.Visible = Editor.Editing
		self.AlignCenterButton.Visible = Editor.Editing
		
		CommentBox.Text = CommentText
		CommentLabel.Text = CommentText
		CommentBox.TextScaled = TextScaled
		CommentBox.TextXAlignment = XAlignment and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
		
		CommentLabel.TextScaled = TextScaled
		CommentLabel.TextXAlignment = XAlignment and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
		
		self.EditButton.MouseButton1Down:connect(function()
			CommentBox.Visible = true
			CommentBox:CaptureFocus()
			CommentLabel.Visible = false
		end)
		
		CommentBox:GetPropertyChangedSignal("Text"):connect(function()
			CommentLabel.Text = CommentBox.Text
		end)
		
		self.TextScaledButton.MouseButton1Down:connect(function()
			TextScaled = not TextScaled
			self.node:SetParameter("TextScaled",TextScaled)
			CommentBox.TextScaled = TextScaled
			CommentLabel.TextScaled = TextScaled
		end)
		self.AlignCenterButton.MouseButton1Down:connect(function() 
			XAlignment = not XAlignment
			self.node:SetParameter("CenterAligned",XAlignment)
			CommentBox.TextXAlignment = XAlignment and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
			CommentLabel.TextXAlignment = XAlignment and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
		end)
		CommentBox.FocusLost:connect(function(enterpressed)
			self.node:SetParameter("CommentText",CommentBox.Text)
			
			CommentBox.Visible = false
			CommentLabel.Visible = true
		end)
	end
	
	if not Editor.Editing then
		if self.Options then
			self.Options.Visible = false
		end
		self.Dragger.Visible = false
		self.SizeDragger.Visible = false
		
		for i,v in pairs(gui:GetDescendants()) do
			if v:isA("TextBox") then
				v.Active = false
				v.TextEditable = false
				v.Selectable = false
				v.ClearTextOnFocus = false
			end
		end
	end

	local sizeValue = self.node.folder.Size
	
	local numparams = 0
	for i,v in pairs(self.parameters) do
		numparams += 1
	end
		
	local startY = sizeValue.Value.Y
	if startY == 92 then
		sizeValue.Value = Vector3.new(sizeValue.Value.x,(startY - 28) + (28 * numparams))
	end
	
	gui:GetPropertyChangedSignal("Size"):connect(function()
		sizeValue.Value=Vector3.new(gui.Size.X.Offset,gui.Size.Y.Offset,0)
	end)
	
	self:SetSize(UDim2.new(0,sizeValue.Value.X,0,sizeValue.Value.Y))
	
	-------- ModuleScript edit buttons for task --------
	if isTask then
		self.EditButton.MouseEnter:connect(function()
			TooltipDisplay(self.EditButton,"Edit")
			self.EditScale.Scale=1.1
		end)
		self.EditButton.MouseLeave:connect(function()
			self.EditScale.Scale=1
			Tooltip.Visible=false
		end)
		self.EditButton.MouseButton1Down:connect(function()
			self.node:OpenTask()
			Tooltip.Visible=false
		end)
			
				
		self.LinkedDuplicateButton.MouseEnter:connect(function()
			self.LinkedDuplicateScale.Scale=1.1
			TooltipDisplay(self.LinkedDuplicateButton,"Linked Duplicate")
		end)
		self.LinkedDuplicateButton.MouseLeave:connect(function()
			self.LinkedDuplicateScale.Scale=1
			Tooltip.Visible=false
		end)
		self.LinkedDuplicateButton.MouseButton1Down:connect(function()
			self:LinkedDuplicate()
			Tooltip.Visible=false
		end)
		
		if self.IsLinked then
			self.DuplicateButton.Visible=false
		end
	elseif self.isExternalTask then
		self.EditButton.MouseEnter:connect(function()
			TooltipDisplay(self.EditButton,"Edit Source")
			self.EditScale.Scale=1.1
		end)
		self.EditButton.MouseLeave:connect(function()
			self.EditScale.Scale=1
			Tooltip.Visible=false
		end)
		self.EditButton.MouseButton1Down:connect(function()
			self.node:OpenTask()
			Tooltip.Visible=false
		end)
		
	elseif not self.isComment then
		self.EditButton:Destroy()
		self.LinkedDuplicateButton:Destroy()
	end
	
	
	-------- Name change --------
	self.Title:GetPropertyChangedSignal("Text"):connect(function()
		self.Title.Shadow.Text=self.Title.Text
		if self.isRoot then 
			node.tree.folder.Name=self.Title.Text
		else
			node:SetName(self.Title.Text)
		end
	end)
	
	
	if not self.isComment then
	
		-------- Duplicate button --------
		self.DuplicateButton.MouseEnter:connect(function()
			self.DuplicateScale.Scale=1.1
			TooltipDisplay(self.DuplicateButton,"Duplicate")
		end)
		self.DuplicateButton.MouseLeave:connect(function()
			self.DuplicateScale.Scale=1
			Tooltip.Visible=false
		end)
		self.DuplicateButton.MouseButton1Down:connect(function()
			self:Duplicate()
			Tooltip.Visible=false
		end)
		
		
		-------- Parameters --------
		self.Parameters = {}
		
		for parameterKey, paramInfo in pairs(self.parameters) do
			local value = self.node:GetParameter(parameterKey)
			if value == nil and not paramInfo.IsObject then
				value = paramInfo.Default
				self.node:SetParameter(parameterKey, value)
			end
			local parameterGui = gui.Parameters.ParameterTemplate:Clone()
			parameterGui.ParameterKey.Text = paramInfo.Display or parameterKey
			parameterGui.Visible = parameterKey ~= "Index"
			parameterGui.LayoutOrder = paramInfo.Sort or parameterKey == "Index" and 0 or 1
			
			parameterGui.Parent = gui.Parameters
			
			self.Parameters[parameterKey] = parameterGui
			
			local isBool = typeof(value) == "boolean"
			local isObject = paramInfo.IsObject
			local textInput = parameterGui.Value.ValueInput
			
			if not isBool and not isObject then
				
				local Options = paramInfo.Options
				if not Options then
					
					local _, overText = paramInfo.Input(value)			

					textInput.PlaceholderText = paramInfo.Placeholder or ""
					
					textInput.Text = overText or value

					textInput.FocusLost:connect(function(enterPressed)
						if not Editor.Editing then
							return
						end
						if not enterPressed then
							local _, overText = paramInfo.Input(value)
							textInput.Text = overText or value
						else
							local v, overText = paramInfo.Input(textInput.Text)
							if v then
								value = v
								textInput.Text = overText or value
								self.node:SetParameter(parameterKey, value)
							else
								textInput.Text = value
							end
						end
					end)
				else
					textInput.Text = value
					
					textInput.Focused:Connect(function()
						textInput:ReleaseFocus()
						if not Editor.Editing then
							return
						end
						local index = table.find(Options,value)
						if index then
							local newindex = index + 1
							if newindex > #Options then
								newindex = 1
							end
							value = Options[newindex]
							textInput.Text = value
							self.node:SetParameter(parameterKey, value)
						end
					end)
				end
			elseif isBool then
				
				local trueText = paramInfo.TrueText or "✓"
				local falseText = paramInfo.FalseText or ""
				
				textInput.Text = value and trueText or falseText
				textInput.Focused:Connect(function()
					textInput:ReleaseFocus()
					if not Editor.Editing then
						return
					end
					value = not value
					textInput.Text = value and trueText or falseText
					self.node:SetParameter(parameterKey, value)
				end)
			elseif isObject then
				
				
				if value ~= nil then textInput.Text = value.Name else textInput.Text = "None" end
				local prevSelectionText = textInput.Text
				textInput.Focused:Connect(function()
					textInput:ReleaseFocus()
					textInput.Text = "Select new source..."
					Editor.Locked = true
					Selection.SelectionChanged:Wait()
					local selectedObject = Selection:Get()[1]
					
					if selectedObject then 
						Selection:Remove({selectedObject})
						Selection:Set({self.node.tree.folder})
						Editor.Locked = false
						if not selectedObject:IsA("ModuleScript") then 
							warn("Selected source must be a modulescript!")
							textInput.Text = prevSelectionText
							return 
						end 
						value = selectedObject
						textInput.Text = selectedObject.Name
						self.node:SetParameter(parameterKey, value)
					end
				end)
			end
			
		end
		
		
		
		-------- Output node connecting --------
		if self.OutputButton then
			self.OutputOver.MouseEnter:connect(function()
				if not Editor.Editing then
					return
				end
				pcall(function()
					self.OutputButton.UIScale.Scale=1.1
					self.OutputButton.Circle.ImageColor3=Color3.new(1,1,1)
				end)
			end)
			self.OutputOver.MouseLeave:connect(function()
				pcall(function()
					self.OutputButton.UIScale.Scale=1
					self.OutputButton.Circle.ImageColor3=Color3.fromRGB(112, 186, 255)
				end)
			end)
			self.OutputOver.MouseButton1Down:connect(function()
				if not Editor.Editing then
					return
				end
				Connectors:StartDrawing(self)
			end)
		end
		
		-------- Input node button --------
		if self.InputButton then
			self.InputOverEnter = self.InputOver.MouseEnter:connect(function()
				if not Editor.Editing then
					return
				end
				pcall(function()
					self.InputOverBool=true
					self.InputButton.UIScale.Scale=1.1
					self.InputButton.Circle.ImageColor3=Color3.new(1,1,1)
				end)
			end)
			self.InputOverLeave = self.InputOver.MouseLeave:connect(function()
				pcall(function()
					self.InputOverBool=false
					self.InputButton.UIScale.Scale=1
					self.InputButton.Circle.ImageColor3=Color3.fromRGB(112, 186, 255)
				end)
			end)
		end
		
		self:SetGradient()
		

		if self.nodeInfo.Icon then
			self.HeaderIconImage.Image = "rbxassetid://"..self.nodeInfo.Icon
		end

		if self.IsLinked then
			self.Type.Text = "Linked Task"
		else
			self.Type.Text = nodeType	
		end
	end
	
	
	Editor.GuiNodes[node]=self

	local x,xo,y,yo = self.node.folder.Position.Value:match("(.-),(.-),(.-),(.+)")
	if x then
		x=tonumber(x)
		xo=tonumber(xo)
		y=tonumber(y)
		yo=tonumber(yo)
		self:MoveTo(x,xo,y,yo)
	end

	-- Create connection

	self:CreateLineConnection()

	local inputNode = self.node.Input
	if inputNode then
		local Outputs = inputNode:GetOutputs()
		for i = 1,#Outputs do
			local value = Outputs[i]
			if value then
				local folder = value.Value
				if folder == self.node.folder then
					self:UpdateSort(i)
					break
				end
			end
		end
	end

	if self.node.tree.Root == self.node then
		self:SetRoot()
	else
		self:SetName(node.name)	
	end
	
	
	self.Dragger.MouseEnter:connect(function()
		self.Dragger.DraggerImage.ImageTransparency=0
	end)
	self.Dragger.MouseLeave:connect(function()
		self.Dragger.DraggerImage.ImageTransparency=0.25
	end)
	self.Dragger.MouseButton1Down:connect(function()
		Editor:DragStarted(self)
	end)
	self.Dragger.MouseButton1Up:connect(function()
		Editor:DragEnded(self)
	end)

	self.SizeDragger.MouseButton1Down:connect(function()
		Editor:SizeDragStarted(self.SizeDragger)	
	end)
	self.SizeDragger.MouseButton1Up:connect(function()
		Editor:SizeDragEnded()
	end)
	
	
	return self
end
function GuiNode:SetGradient(gradientType)
	self.GradientHolder.Gradient:Destroy()
	local clone
	if self.nodeType == "Root" and not self.isRoot then
		clone = self.nodeInfo.InactiveGradient:Clone()
	else
		clone = self.nodeInfo.Gradient:clone()
	end
	clone.Name="Gradient"
	clone.Parent=self.GradientHolder
end
function GuiNode:SetRoot()
	self.isRoot=true
	self.Dragger.AnchorPoint=Vector2.new(0,1)
	self.Dragger.Position=UDim2.new(0,0,0,0)
	self:SetName(self.node.tree.folder.Name)
	self:SetGradient()
	self.Type.Text=self.Type.Text.."(ROOT)"
end

function GuiNode:Duplicate()
	if self.IsLinked then
		return
	end
	
	local params = {}
	for parameterKey, paramInfo in pairs(self.parameters) do
		params[parameterKey] = self.node:GetParameter(parameterKey)
	end
	
	local newNode = Editor:CreateNode(self.nodeType, params)
	if newNode then
		newNode.GuiNode:MoveToPositionAtMouse(0,self.gui.AbsoluteSize.y)
		newNode.GuiNode:SetSize(self.gui.Size)
	end
end
function GuiNode:LinkedDuplicate()
	local newNode = Editor:CreateLinkedNode(self.node)
	if newNode then
		newNode.GuiNode:MoveToPositionAtMouse(0,self.gui.AbsoluteSize.y)
		newNode.GuiNode:SetSize(self.gui.Size)
	end
end

function GuiNode:ClearLine(othernode)
	Connectors:ClearLine(self,othernode)
end
function GuiNode:SetSize(size)
	self.gui.Size = size
end

function GuiNode:UpdateSort(i)
	Connectors:UpdateLines()
	if not i then
		self.Parameters.Index.Visible = false
	else
		self.Parameters.Index.Value.ValueInput.Text = i
		self.Parameters.Index.Visible = true
	end
end
function GuiNode:AutoCalculateSort()
	local inputNode = self.node.Input
	if inputNode then
		local nodes = {}
		local Outputs = inputNode:GetOutputs()
		for i = 1,#Outputs do
			local value = Outputs[i];
			if value then
				local folder = value.Value;
				if folder then
					local node = Editor.Opened:GetNodeByFolder(folder);
					if node and node.GuiNode then
						table.insert(nodes, node)
					end
				end
			end
		end
		table.sort(nodes, function(a, b) return a.GuiNode.gui.AbsolutePosition.X < b.GuiNode.gui.AbsolutePosition.X end)
		for i, node in pairs(nodes) do
			if i ~= node.OutputSort then
				node:AttemptManualResort(i)
			end
		end
	end
end
function GuiNode:CreateLineConnection()
	self:AutoCalculateSort()
	local inputNode = self.node.Input
	if self.LineConnection then
		self.LineConnection:Dispose()
		self.LineConnection=nil
	end
	if inputNode then
		local guiNode = Editor.GuiNodes[inputNode] or GuiNode.new(inputNode)
		if guiNode then
			self.LineConnection = Connectors:LineConnection(guiNode,self)
		end
	end
end


function GuiNode:MoveTo(x,xo,y,yo)
	self.gui.Position=UDim2.new(x,xo,y,yo)
	self.node.folder.Position.Value = x..","..xo..","..y..","..yo
end


function GuiNode:MoveToPositionAtMouse(ox, oy, dontUpdateLines)
	if not ox then
		ox=0
	end
	if not oy then
		oy=1
	end
	
	-- Move output nodes together
	local Outputs = self.node:GetOutputs()
	for i = 1,#Outputs do
		local value = Outputs[i];
		if value then
			local folder = value.Value;
			if folder then
				local node = Editor.Opened:GetNodeByFolder(folder);
				if node and node.GuiNode then
					local nox = ox + node.GuiNode.gui.AbsolutePosition.X - self.gui.AbsolutePosition.X
					local noy = oy + node.GuiNode.gui.AbsolutePosition.Y - self.gui.AbsolutePosition.Y
					node.GuiNode:MoveToPositionAtMouse(nox, noy, true)
				end
			end
		end
	end
	
	local mouseX,mouseY = Editor:GetMouseLocationInWorkspace()
	mouseX = mouseX + ox
	mouseY = mouseY + oy
	local Workspace = Editor.Workspace
	local abssize = Workspace.AbsoluteSize
	self:MoveTo(math.clamp(mouseX / abssize.x,0,1),0,math.clamp(mouseY/abssize.y,0,1),0)
	
	if not dontUpdateLines then
		Connectors:UpdateLines()
	end
end

function GuiNode:SetName(s)
	if s == "Root" and not self.isRoot then
		warn("Can't name a node 'Root'!")
		s = self.gui.Name
	end
	self.gui.Name=s
	self.Title.Text=s
	self.Title.Shadow.Text=s
end
function GuiNode:Dispose()
	self.Active=false
	Editor.GuiNodes[self.node]=nil
	self.node.GuiNode=nil
	pcall(function() self.gui:Destroy() end)
	Connectors:UpdateLines()
end


function Editor:GetMouseLocationInWorkspace()
	local mouseX = PluginMouse.x - self.Workspace.AbsolutePosition.x
	local mouseY = PluginMouse.y - self.Workspace.AbsolutePosition.y
	return mouseX,mouseY
end
function Editor:SizeDragUpdate()
	local self = Editor
	local mouseX = PluginMouse.x
	local mouseY = PluginMouse.y
	local DragSize = self.SizeDragSize
	local DragPos = self.SizeDragPosition
	local sizeX = (mouseX - DragPos.x) - 15
	local sizeY = mouseY - DragPos.y
	self.SizeDragging.Size = UDim2.new(0,sizeX,0,sizeY)
	Connectors:UpdateLines()
end
function Editor:DragUpdate()
	local self = Editor
	local node = self.DraggingNode
	local mouseX = PluginMouse.x
	local mouseY = PluginMouse.y
	if mouseX ~= self.LastDragX or mouseY ~= self.LastDragY then
		self.trueDragging=true
    	node:MoveToPositionAtMouse(-self.DragOffsetX, -self.DragOffsetY)
	end
	self.LastDragX=mouseX
	self.LastDragY=mouseY
	
	if self.trueDragging and not self.lastTrueDragging then
		self.Trash.Visible=true
		local tweenInfo = TweenInfo.new(0.15)
		local tweenInfo2 = TweenInfo.new(0.15,Enum.EasingStyle.Linear,Enum.EasingDirection.Out,0,true,0)
	
		self:CancelTrashTweens()
		
		self.TrashTweens = {
			TweenService:Create(self.TrashImage,tweenInfo,{ImageTransparency=0}),
			TweenService:Create(self.TrashBackground,tweenInfo,{ImageTransparency=0.25}),
			TweenService:Create(self.TrashScale,tweenInfo2,{Scale=1}),
		}
		for i,v in pairs(self.TrashTweens) do
			v:Play()
		end		
	end
	self.lastTrueDragging=self.trueDragging
end
function Editor:SizeDragStarted(button)
	self:StopPan()
	self:SizeDragEnded()
	self.SizeDragging=button.Parent
	self.SizeDragSize = self.SizeDragging.AbsoluteSize
	self.SizeDragPosition = self.SizeDragging.AbsolutePosition
	RunService:BindToRenderStep("BehaviorTreeSizeDrag",Enum.RenderPriority.Last.Value,self.SizeDragUpdate)
end
function Editor:SizeDragEnded()
	self.SizeDragging=nil
	self:StopPan()
	RunService:UnbindFromRenderStep("BehaviorTreeSizeDrag")
end
function Editor:DragStarted(node)
	self:StopPan()
	self:DragEnded(node)
	self.DraggingNode = node
  	self.DragOffsetX = PluginMouse.x - node.gui.AbsolutePosition.X
 	self.DragOffsetY = PluginMouse.y - node.gui.AbsolutePosition.Y
	self.lastTrueDragging=false
	self.trueDragging=false
	RunService:BindToRenderStep("BehaviorTreeDrag",Enum.RenderPriority.Last.Value,self.DragUpdate)
end
function Editor:DragEnded(node)
	if self.DraggingNode ~= node then
		return
	end
	self:StopPan()
	RunService:UnbindFromRenderStep("BehaviorTreeDrag")
	self.DraggingNode=nil	
	self:CancelTrashTweens()
	self.TrashImage.ImageTransparency=1
	self.TrashBackground.ImageTransparency=1
	self.TrashScale.Scale=0.75	
	self.Trash.Visible=false
	
	if self.TrashEntered then
		self:DeletePrompt(node)
	else
		node:AutoCalculateSort()
	end
	self.TrashEntered=false
end
function Editor:DeletePrompt(node)
	local mouseX = PluginMouse.x
	local mouseY = PluginMouse.y
	self.ConfirmDelete.Position=UDim2.new(0,mouseX,0,mouseY)
	self.DeleteDesc.Text = string.format("Are you sure you want to delete %s, including any code that may be attached to it?",node.gui.Name)
	self.Deleting=node
	self.ConfirmDelete.Visible=true
end
function Editor:DeleteCancelAction()
	self.ConfirmDelete.Visible=false
	self.Deleting=nil
end
function Editor:DeleteConfirmAction()
	self.ConfirmDelete.Visible=false
	if self.Deleting then
		self.Deleting.node:Dispose() -- Delete the actual node
	end
	self.Deleting=nil
end

function Editor:CancelTrashTweens()
	if self.TrashTweens then
		for i,v in pairs(self.TrashTweens) do
			v:Cancel()
		end
	end
end
function Editor:IsInUIObject(obj)
	local abspos = obj.AbsolutePosition
	local abssize = obj.AbsoluteSize
	abspos=abspos+abssize/2
	
	local x = PluginMouse.x
	local y = PluginMouse.y
	local inBounds = x < abspos.x + abssize.x/2 and x > abspos.x - abssize.x/2 and y < abspos.y + abssize.y/2 and y > abspos.y - abssize.y/2
	return inBounds
end


function Editor:Close()
	if self.Locked then return end
	if self.DebugStep then
		self.DebugStep:disconnect()
		self.DebugStep = nil
	end
	self:CloseHelp()
	self:CloseQuickAdd()
	self:StopPan()
	Tooltip.Visible=false
	Connectors:Close()
	PluginExit.Enabled=false
	self.EditorScreen.Visible=false
	self.Toolbar.Visible=false
	self.Vignette.Visible=false
	for node,guinode in pairs(self.GuiNodes) do
		if guinode then
			guinode:Dispose()
		end
	end
	self:DeleteCancelAction()
	PluginMouse.Icon=PluginMouseIcon
	self.Opened=nil
end
function Editor:NodeAdded(node)
	if not self.GuiNodes[node] then
		if node.tree == self.Opened then
			return GuiNode.new(node)
		end
	end
end


function Editor:Open(Tree,Editing)
	if self.Locked then return end
	Keybinds = self:GetKeybinds()
	for i,v in pairs(defaultBinds) do
		if not Keybinds[i] then
			Keybinds[i]=v
		end
	end
	pcall(function()
		self.BindsFrame.Delete.Button.Bind.Text = Keybinds.Delete
		self.BindsFrame.Duplicate.Button.Bind.Text = Keybinds.Duplicate
		self.BindsFrame.LinkedDuplicate.Button.Bind.Text = Keybinds.LinkedDuplicate
		self.BindsFrame.Edit.Button.Bind.Text = Keybinds.Edit
	end)
	self:Close()	
	self.ZoomScale.Scale=1
	self.EditorScreen.Visible=true
	self.Toolbar.Visible=true
	self.Vignette.Visible=true
	PluginExit.Enabled=true
	self.Opened=Tree
	
	
	self.ToolHelp.Visible = Editing
	self.ToolCreate.Visible = Editing
	
	self.Editing = Editing
	
	
	for i = 1,#Tree.Nodes do
		local node = Tree.Nodes[i]
		if node then
			GuiNode.new(node)
		end
	end
	local folder = Tree.folder
	local workspaceX = folder.WorkspaceX.Value
	local workspaceY = folder.WorkspaceY.Value
	local Zoom = folder.Zoom.Value
	if workspaceX.X ~= -1 and workspaceY.X ~= -1 then
		self.Workspace.Position=UDim2.new(workspaceX.X,workspaceX.Y,workspaceY.X,workspaceY.Y)
	else
		self.Workspace.Position=UDim2.new(0.5,0,0.5,0)
	end
	self.ZoomScale.Scale=Zoom	
	Connectors:UpdateLines()
	
	local RanBefore = plugin:GetSetting("RanBefore") or not Editing
	if not RanBefore then
		self:OpenHelp()
		plugin:SetSetting("RanBefore",true)
	end
	
	
	self.LastDebugNode = nil
	self.LastLineConnections = {}

	if not self.Editing then
		self.DebugStep = RunService.Heartbeat:connect(function(dt)
			self:DebugStepFunction(dt)
		end)
	end
end
function Editor:DebugStepFunction(dt)
	local Tree = self.Opened
	local DebugNode = self.DebugNode

	local guinode,path
	if DebugNode then
		DebugNode = DebugNode.Value

		local node = Tree:GetNodeByFolder(DebugNode)
		if node then

			local foundnode = node.GuiNode
			local DebugPath = Tree.DebugPaths[node]

			if foundnode and DebugPath then
				guinode = foundnode
				path = DebugPath
			end
		end
	end

	if guinode ~= self.LastDebugNode then
		if self.LastDebugNode then
			self.LastDebugNode.Highlight.Visible = false
		end	
		if self.LastLineConnections then
			for i,connection in pairs(self.LastLineConnections) do
				connection.ForceColor = nil
			end
		end

		if guinode then
			guinode.Highlight.Visible = true

			table.clear(self.LastLineConnections)
			for i = 1,#path-1 do
				local from = path[i]
				local to = path[i+1]
				if from and to then

					local fromnode = from.GuiNode
					local tonode = to.GuiNode

					if fromnode and tonode then
						local LineConnection = Connectors:GetLineConnection(fromnode,tonode)
						if LineConnection then
							local color = Color3.fromRGB(252, 227, 6)
							LineConnection.ForceColor = color
							table.insert(self.LastLineConnections,LineConnection)
						end
					end
				end
			end
		end
	end
	
	
	self:ClampWorkspace()

	if guinode then
		guinode.Highlight.UIGradient.Transparency = NumberSequence.new(0.2 + math.sin(os.clock() * 5) * 0.2) 
	end

	self.LastDebugNode = guinode		
end

function Editor:CreateNode(nodeType, initParams)
	self:CloseQuickAdd()
	if self.Opened then 
		local newNode = self.Opened:CreateNode(nil,nodeType,nil,initParams)
		if newNode.GuiNode then
			newNode.GuiNode:MoveToPositionAtMouse()
			return newNode
		end
	end
end
function Editor:CreateLinkedNode(node)
	self:CloseQuickAdd()
	if self.Opened then 
		local newNode = self.Opened:CreateLinkedNode(node)
		if newNode.GuiNode then
			newNode.GuiNode:MoveToPositionAtMouse()
			return newNode
		end
	end
end

function Editor:CloseQuickAdd()
	self.QuickAdd.Visible=false
	self.QuickAddOpen=false
	self.Background_Open.Visible=false
	self.Background_Closed.Visible=true
end
function Editor:ToggleQuickAdd(clickedToolbar)
	if not self.QuickAddOpen then
		local x = PluginMouse.x
		local y = PluginMouse.y
		if clickedToolbar then
			x = self.Background_Open.AbsolutePosition.X
			y = self.Background_Open.AbsolutePosition.Y + self.Background_Open.AbsoluteSize.Y + 6
		else
			local viewy = PluginMouse.ViewSizeY
			local viewx = PluginMouse.ViewSizeX
			local bottom = y + self.QuickAdd.AbsoluteSize.Y
			local right = x + self.QuickAdd.AbsoluteSize.X
			local left = x - self.QuickAdd.AbsoluteSize.X
						
			if bottom > viewy then
				local diff = bottom - viewy 
				y -= diff
			end
			if right > viewx then
				local diff = right - viewx
								
				x -= diff
			end
			if left < 0 then
				x = 0
			end
		end
		self.QuickAdd.Position=UDim2.new(0,x,0,y)
		self.QuickAdd.Visible=true
		self.QuickAddOpen=true
		self.Background_Open.Visible=true
		self.Background_Closed.Visible=false
	else
		self:CloseQuickAdd()
	end
end

function Editor:ZoomOut()
	if not self.Opened then
		return
	end
	if self:IsInUIObject(self.Help) and self.Help.Visible then
		return
	end
	local mousePos = Vector2.new(PluginMouse.x,PluginMouse.y)
	local relativeBeforeScale = (mousePos - self.Workspace.AbsolutePosition) / self.Workspace.AbsoluteSize
	self.ZoomScale.Scale = math.clamp(self.ZoomScale.Scale-ZOOMSPEED,ZOOM_MIN,ZOOM_MAX)
	local newPosition = self.Workspace.AbsolutePosition + relativeBeforeScale * self.Workspace.AbsoluteSize
	self.Workspace.Position = self.Workspace.Position + UDim2.new(0, mousePos.X - newPosition.X, 0, mousePos.Y - newPosition.Y)	
	self:ClampWorkspace()
end
function Editor:ZoomIn()
	if not self.Opened then
		return
	end
	if self:IsInUIObject(self.Help) and self.Help.Visible then
		return
	end
	local mousePos = Vector2.new(PluginMouse.x,PluginMouse.y)
	local relativeBeforeScale = (mousePos - self.Workspace.AbsolutePosition) / self.Workspace.AbsoluteSize
	self.ZoomScale.Scale = math.clamp(self.ZoomScale.Scale+ZOOMSPEED,ZOOM_MIN,ZOOM_MAX)
	local newPosition = self.Workspace.AbsolutePosition + relativeBeforeScale * self.Workspace.AbsoluteSize
	self.Workspace.Position = self.Workspace.Position + UDim2.new(0, mousePos.X - newPosition.X, 0, mousePos.Y - newPosition.Y)
	self:ClampWorkspace()
end
function Editor:ClampWorkspace()
	pcall(function()
	local absPos = self.Workspace.AbsolutePosition
	local absSize = self.Workspace.AbsoluteSize
	local clampedX = math.clamp(absPos.x,PluginMouse.ViewSizeX - absSize.x, 0)	
	local clampedY = math.clamp(absPos.y,PluginMouse.ViewSizeY - absSize.y, 0)
	self.Workspace.Position = self.Workspace.Position + UDim2.new(0, clampedX - absPos.x, 0, clampedY - absPos.y)
	
	local folder = self.Opened.folder
	local workspaceX = folder.WorkspaceX
	local workspaceY = folder.WorkspaceY
	workspaceX.Value = Vector3.new(self.Workspace.Position.X.Scale,self.Workspace.Position.X.Offset,0)
	workspaceY.Value = Vector3.new(self.Workspace.Position.Y.Scale,self.Workspace.Position.Y.Offset,0)
	Connectors:UpdateLines()
	end)
end
function Editor:PanUpdate()
	local self = Editor
	local mousePos = Vector2.new(PluginMouse.x,PluginMouse.y)
	local lastMousePos = self.lastPan or mousePos
	local moveX = mousePos.X-lastMousePos.X
	local moveY = mousePos.Y-lastMousePos.Y
	
	self.Workspace.Position = self.Workspace.Position + UDim2.new(0,moveX,0,moveY)
	
	if self.Editing then self:ClampWorkspace() end
	self.lastPan = mousePos
end
function Editor:StartPan()
	if self.DraggingNode then
		return
	end
	if self.SizeDragging then
		return
	end
	if not self.Opened then
		return
	end
	if UserInputService:GetFocusedTextBox() then
		return
	end
	if Connectors.DrawingLine then
		return
	end
	if self:IsInUIObject(self.Help) and self.Help.Visible then
		return
	end
	local mousePos = Vector2.new(PluginMouse.x,PluginMouse.y)
	self.lastPan=mousePos
	RunService:BindToRenderStep("BehaviorTreePan",Enum.RenderPriority.Last.Value,self.PanUpdate)
	PluginMouse.Icon="rbxasset://textures/advClosed-hand.png"
	self.Panning=true
end
function Editor:StopPan()
	PluginMouse.Icon=PluginMouseIcon
	RunService:UnbindFromRenderStep("BehaviorTreePan")
	self.Panning=false
end
function Editor:OpenHelp()
	local list = self.Help.Body.ScrollingFrame
	local bindsList = self.Help.Body.BindsFrame
	if not self.HelpNodesLoaded then
		local template = list.Block_Template
		template.Parent = nil
		for _, nodeInfo in pairs(NodeInfo.List) do
			local newBlock = template:Clone()
			newBlock.Body.Title.Text = nodeInfo.Name
			newBlock.Body.Title.Shadow.Text = nodeInfo.Name
			newBlock.Body.Details.Text = nodeInfo.Description
			newBlock.Parent = list
			local textSize = TextService:GetTextSize(nodeInfo.Description, newBlock.Body.Details.TextSize, newBlock.Body.Details.Font, newBlock.Body.Details.AbsoluteSize + Vector2.new(0, 1000))
			newBlock.Size = UDim2.new(1, 0, 0, newBlock.AbsoluteSize.Y - newBlock.Body.Details.AbsoluteSize.Y + textSize.Y)
			if nodeInfo.Gradient then
				local gradient = newBlock:FindFirstChild("UIGradient", true)
				gradient.Color = nodeInfo.Gradient.Color
			end
		end
		self.HelpNodesLoaded = true
	end
	list.CanvasSize = UDim2.new(0, 0, 0, list.UIListLayout.AbsoluteContentSize.Y + list.UIListLayout.Padding.Offset * 2)
	bindsList.CanvasSize = UDim2.new(0, 0, 0, bindsList.UIListLayout.AbsoluteContentSize.Y + bindsList.UIListLayout.Padding.Offset * 2)
	self.Help.Visible=true
end
function Editor:CloseHelp()
	self.Help.Visible=false
end

function Editor:Init(exit,mouse,Plugin)
	
	PluginExit=exit
	plugin=Plugin
	PluginMouse=mouse
	PluginMouseIcon=mouse.Icon


	if CoreGui:FindFirstChild("BTreeGui") then
		CoreGui.BTreeGui:Destroy()
	end
	local Gui = script.BTreeGui:clone()
	Gui.Parent=CoreGui
	
	Editor.TreeGui=Gui


	local preloading = {}
	for i,v in pairs(Gui:GetDescendants()) do
		if v:isA("ImageLabel") or v:isA("ImageButton") then
			table.insert(preloading,v)
		end
		if not Editor[v.Name] then
			Editor[v.Name]=v
		end
	end
	
	NodeTemplate = Editor.NodeTemplate:clone()
	CommentTemplate = Editor.CommentTemplate:clone()
	
	Tooltip = Editor.Tooltip
	
	Editor.NodeTemplate:Destroy()
	Editor.CommentTemplate:Destroy()

	spawn(function()
		ContentProvider:PreloadAsync(preloading)
	end)
	

	
	Connectors:Init(mouse,self)
	self:Close()

	
	
	self.ToolCreate.MouseEnter:connect(function()
		self.ToolCreate.Background_Closed.BG.ImageColor3=Color3.fromRGB(113,113,113)
	end)
	self.ToolCreate.MouseLeave:connect(function()
		self.ToolCreate.Background_Closed.BG.ImageColor3=Color3.fromRGB(67,67,67)
	end)
	
	self.ToolHelp.MouseEnter:connect(function()
		self.ToolHelp.Background.BG.ImageColor3=Color3.fromRGB(113,113,113)
	end)
	self.ToolHelp.MouseLeave:connect(function()
		self.ToolHelp.Background.BG.ImageColor3=Color3.fromRGB(67,67,67)
	end)
	self.ToolHelp.MouseButton1Down:connect(function()
		if self.Help.Visible then
			self:CloseHelp()
		else
			self:OpenHelp()
		end
	end)
	
	self.HelpClose.MouseEnter:connect(function()
		self.HelpClose.UIScale.Scale=1.05
		self.HelpClose.Icon.ImageColor3=Color3.new(1,1,1)
	end)
	self.HelpClose.MouseLeave:connect(function()
		self.HelpClose.UIScale.Scale=1
		self.HelpClose.Icon.ImageColor3=Color3.fromRGB(152,52,52)
	end)
	self.HelpClose.MouseButton1Down:connect(function()
		self:CloseHelp()	
	end)

	
	self.QuickAddClose.MouseEnter:connect(function()
		self.QuickAddClose.UIScale.Scale=1.05
		self.QuickAddClose.Icon.ImageColor3=Color3.new(1,1,1)
	end)
	self.QuickAddClose.MouseLeave:connect(function()
		self.QuickAddClose.UIScale.Scale=1
		self.QuickAddClose.Icon.ImageColor3=Color3.fromRGB(152,52,52)
	end)
	self.QuickAddClose.MouseButton1Down:connect(function()
		self:CloseQuickAdd()
	end)
	
	
	self.ToolCreate.MouseButton1Down:connect(function()
		Editor:ToggleQuickAdd(true)
	end)
	
	self.ToolClose.MouseEnter:connect(function()
		self.ToolClose.Background.BG.ImageColor3=Color3.fromRGB(113,113,113)
	end)
	self.ToolClose.MouseLeave:connect(function()
		self.ToolClose.Background.BG.ImageColor3=Color3.fromRGB(67,67,67)
	end)
	self.ToolClose.MouseButton1Click:connect(function()
		self:Close()
		Selection:Set({})
	end)
	self.Trash.Icon.MouseEnter:connect(function()
		if not self.Trash.Visible then
			return
		end
		self.TrashEntered=true
		self:CancelTrashTweens()
		self.TrashGradient.Transparency=NumberSequence.new(0)
		self.TrashScale.Scale=0.85
		self.TrashBackground.ImageTransparency=0.25
		self.TrashImage.ImageTransparency=0
	end)
	self.Trash.Icon.MouseLeave:connect(function()
		if not self.Trash.Visible then
			return
		end
		self.TrashEntered=false
		self:CancelTrashTweens()
		self.TrashGradient.Transparency=NumberSequence.new(0.5)
		self.TrashBackground.ImageTransparency=0.25
		self.TrashScale.Scale=0.75
		self.TrashImage.ImageTransparency=0
	end)
	self.DeleteConfirm.MouseEnter:connect(function()
		self.DeleteConfirm.UIScale.Scale=1.05
	end)
	self.DeleteConfirm.MouseLeave:connect(function()
		self.DeleteConfirm.UIScale.Scale=1
	end)
	self.DeleteConfirm.MouseButton1Down:connect(function()
		self:DeleteConfirmAction()
	end)
	self.DeleteCancel.MouseEnter:connect(function()
		self.DeleteCancel.UIScale.Scale=1.05
	end)
	self.DeleteCancel.MouseLeave:connect(function()
		self.DeleteCancel.UIScale.Scale=1
	end)
	self.DeleteCancel.MouseButton1Down:connect(function()
		self:DeleteCancelAction()
	end)
	
	self:NodeAddUI(self.QuickAdd)
	
	self.Blocker.MouseWheelForward:connect(function()
		self:ZoomIn()
	end)
	self.Blocker.MouseWheelBackward:connect(function()
		self:ZoomOut()
	end)
	self.ZoomScale:GetPropertyChangedSignal("Scale"):connect(function()
		
		local x = self.ZoomScale.Scale
		local value = math.floor(x*10)/10
		
		self.ZoomText.Text = string.format("%sx",tostring(value))
		
		if self.Opened then
			self.Opened.folder.Zoom.Value=self.ZoomScale.Scale
		end
	end)
	
	
	for i,v in pairs(self.BindsFrame:GetChildren()) do
		if v:isA("ImageButton") then
			local input = v.Button.Bind
			input.Focused:connect(function()
				self.BindListening=input
			end)
		end
	end
end

function Editor:SetBind(input,keycode)
	local canChange = true
	
	local keycodeName = keycode.Name
	
	if keycodeName == Keybinds.Delete or keycodeName == Keybinds.Duplicate then
		canChange=false
	end
	if keycodeName == "H" or keycodeName == "Space" then
		canChange=false
	end
	if not canChange then
		input.Text=Keybinds[input.Parent.Parent.Name]
	else
		input.Text=keycodeName
		Keybinds[input.Parent.Parent.Name]=keycodeName
		Editor:SaveKeybinds()
	end
end

function Editor:NodeAddUI(frame)
	local list = frame.Body
	local template = list.NodeItemTemplate
	template.Visible = false
	for _, nodeInfo in pairs(NodeInfo.List) do
		local button = template:Clone()
		button.Body.Title.Text = nodeInfo.Name
		if nodeInfo.Icon then
			button.Body.Icon.ImageLabel.Image = "rbxassetid://"..nodeInfo.Icon
		end
		if nodeInfo.Gradient then
			button.GradientHolder.Gradient:Destroy()
			local gradient = nodeInfo.Gradient:Clone()
			gradient.Parent = button.GradientHolder
		end
		button.Visible = true
		button.Parent = list
		
		button.MouseEnter:connect(function()
			button.BackgroundTransparency=0.75
		end)
		button.MouseLeave:connect(function()
			button.BackgroundTransparency=1
		end)
		button.MouseButton1Down:connect(function()
			self:CreateNode(nodeInfo.Name)
			self.Background_Open.Visible=false
			self.Background_Closed.Visible=true
		end)
	end
	frame.Size = UDim2.new(0, frame.Size.X.Offset, 0, list.Position.Y.Offset + list.UIListLayout.AbsoluteContentSize.Y + list.UIListLayout.Padding.Offset)
end

function Editor:GetClosestSelectedNode()
	local closest
	local lastdist = 999
	if not self.Opened then
		return
	end
	for _,guinode in pairs(self.GuiNodes) do
		local gui = guinode.gui
		if self:IsInUIObject(gui) then
			local abspos = gui.AbsolutePosition
			local pos = Vector2.new(PluginMouse.x,PluginMouse.y)
			if pos then
				local dist = (pos - abspos).magnitude
				if dist < lastdist then
					lastdist=dist
					closest=guinode
				end
			end
		end
	end	
	return closest
end


UserInputService.InputEnded:connect(function(input,processed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		Connectors:StopDrawing()
		local Dragging = Editor.DraggingNode
		if Dragging then
			Editor:DragEnded(Dragging)
		end
		Editor:SizeDragEnded()
		Editor:StopPan()
	end
end)

UserInputService.InputBegan:connect(function(input,processed)
	if not Editor.Opened then
		return
	end
	if input.UserInputType == Enum.UserInputType.Keyboard and Editor.Editing then
		if Editor.BindListening then
			Editor.BindListening:ReleaseFocus()
			Editor:SetBind(Editor.BindListening,input.KeyCode)
			Editor.BindListening=false
		end
	end
	if input.UserInputType == Enum.UserInputType.Keyboard and not processed and Editor.Editing then
		
		if Editor.Opened then
			if input.KeyCode == Enum.KeyCode.H then
				if Editor.Help.Visible then
					Editor:CloseHelp()
				else
					Editor:OpenHelp()
				end
			end
			if input.KeyCode == Enum.KeyCode.Space then
				Editor:ToggleQuickAdd()
			end
			if Keybinds then				
				if input.KeyCode.Name == Keybinds.Delete then
					local node = Editor:GetClosestSelectedNode()
					if node then
						node.node:Dispose()
					else
						local line = Connectors:GetClosestLine()
						if line then
							line:RemoveConnection()
						end
					end
				elseif input.KeyCode.Name == Keybinds.Duplicate then
					local node = Editor:GetClosestSelectedNode()
					if node then
						node:Duplicate()
					end
				elseif input.KeyCode.Name == Keybinds.Edit then
					local node = Editor:GetClosestSelectedNode()
					if node then
						node.node:OpenTask()
					end
				elseif input.KeyCode.Name == Keybinds.LinkedDuplicate then
					local node = Editor:GetClosestSelectedNode()
					if node then
						node:LinkedDuplicate()
					end
				end
			end
		end
		
	elseif input.UserInputType == Enum.UserInputType.MouseWheel then
		local forward = input.Position.Z > 0
		if forward then
			Editor:ZoomIn()
		else
			Editor:ZoomOut()
		end
	elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
		Editor:StartPan()
	end
end)

return Editor]]></ProtectedString>
					<string name="ScriptGuid">{D91C6361-E5AC-4F26-9838-7CD332E2B6FB}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Editor</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
				<Item class="ModuleScript" referent="RBXB09C8B8C91F3453E8E2DC467082C2889">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Connectors = {}

local RunService = game:GetService("RunService");
local LineTemplate = script.LineHolder;
local PluginMouse;
local Editor;

local Weight = script.Weight;
local drawCurve = require(script.DrawCurve)

Connectors.LineColor = LineTemplate.BackgroundColor3

local function UpdateLine(connector,line,Start,End)
	local ZoomScale = math.max(0.2,Editor.ZoomScale.Scale);
		
	local Thickness = 5 * ZoomScale;
	
	--[[local arrowSize = 22 * ZoomScale;
	line.Arrow.Size = UDim2.new(0,arrowSize,0,arrowSize);
	line.Arrow.Position = UDim2.new(0.5,0,1, arrowSize * 0.1);
	
	local position = (Start + End) / 2
	local dist = (Start - End).Magnitude;
	
	local size = Vector2.new(Thickness,dist)
	
	local displacement = End - Start;
	local rotation = math.atan2(displacement.x,displacement.y);
	
	line.Size = UDim2.new(0 , size.X , 0 , size.Y)
    line.Position = UDim2.new(0 , position.X , 0 , position.Y)
	line.Rotation = -math.deg(rotation)
	]]
	local forcecolor = connector and connector.ForceColor
	
	local segments = drawCurve(Thickness, Thickness * 20, Start, End,forcecolor or Connectors.LineColor, line)
		
	if connector then
		connector.IsIn = false
		
		local inCount = 0
		local weightSegment
		for i, segment in pairs(segments) do
			if i <= #segments * 0.75 then
				weightSegment = segment
			end

			segment.MouseEnter:connect(function()
				inCount=inCount+1
				connector.IsIn=inCount>0;
			end)
			segment.MouseLeave:connect(function()
				inCount=inCount-1
				connector.IsIn=inCount>0;
			end)
		end
		
		local weight = connector.Weight;
		if weight then
			weight.Position=weightSegment.Position;
			weight.UIScale.Scale=ZoomScale;
		end
	end
end



local lineConnection = {};
local lineConnections={};
lineConnection.__index=lineConnection;

function Connectors:GetClosestLine()
	local closest;
	local lastdist = 999;
	for _,line in pairs(lineConnections) do
		
		local drawingline = line.DrawingLine;
		
		if line.IsIn then
			--[[local abspos = drawingline.AbsolutePosition;
			local pos = Vector2.new(PluginMouse.x,PluginMouse.y);
			if pos then
				local dist = (pos - abspos).magnitude;
				if dist < lastdist then
					lastdist=dist;
					closest=line;
				end
			end]]
			closest=line;
		end
	end	
	return closest;
end



function lineConnection.new(inputGui,outputGui)
	if not inputGui or not outputGui then
		return;
	end
	local self = setmetatable({},lineConnection);
	self.outputGui = outputGui;
	self.inputGui = inputGui;
	
	local isRandom = inputGui.node.type == "Random";
	if isRandom then
		self.Weight = Weight:clone();
		self.Weight.Parent=Editor.Lines;
		self.LastWeight = outputGui.node.Weight or 1;
		self.Weight.WeightInput.Text=self.LastWeight;
		self.Weight.WeightInput.FocusLost:connect(function()
			local num = tonumber(self.Weight.WeightInput.Text);
			if not num then
				self.Weight.WeightInput.Text=self.LastWeight;
			else
				num = math.ceil(num)
				self.Weight.WeightInput.Text = num
				outputGui.node:SetWeight(num);
			end
		end)
	end
		
	local DrawingLine = LineTemplate:clone();
	DrawingLine.Visible=false;
	DrawingLine.Parent=Editor.Lines;

	self.DrawingLine=DrawingLine;
		
	--[[DrawingLine.MouseEnter:connect(function()
		self.IsIn=true;
	end)
	DrawingLine.MouseLeave:connect(function()
		self.IsIn=false;
	end)]]
	
	lineConnections[self.outputGui]=self;
	self:Update();
	return self;	
end
function lineConnection:Update()
	local inputGui = self.inputGui;
	local outputGui = self.outputGui;
	if not inputGui or not outputGui then
		self:Dispose();
		return;
	end
	if not inputGui.gui.Parent or not outputGui.gui.Parent then
		self:Dispose();
		return;
	end
	if not inputGui.Active or not outputGui.Active then
		self:Dispose();
		return;
	end
	local OutputCircle = inputGui.OutputButton.Circle;
	local InputCircle = outputGui.InputButton.Circle;
	local Start = OutputCircle.AbsolutePosition + OutputCircle.AbsoluteSize/2;
	local End = InputCircle.AbsolutePosition + InputCircle.AbsoluteSize/2;
	self.DrawingLine.Visible = true
	UpdateLine(self,self.DrawingLine,Start,End);
	self.DrawingLine.Visible = true;
end
function lineConnection:RemoveConnection()
	local inputgui = self.inputGui;
	
	local outputgui = self.outputGui;
	local outputnode = outputgui.node;
	if outputnode then
		inputgui.node:RemoveOutput(outputnode);
	end
	self:Dispose();
end
function lineConnection:Dispose()
	lineConnections[self.outputGui]=nil;
	pcall(function()
		self.DrawingLine:Destroy();
		if self.Weight then
			self.Weight:Destroy();
		end
	end)
end

function Connectors:LineConnection(inputGui,outputGui)
	return lineConnection.new(inputGui,outputGui);
end

function Connectors:ClearLine(nodea,nodeb)
	local obj = self:GetLineConnection(nodea,nodeb)
	if obj then
		obj:Dispose()
	end
end
function Connectors:GetLineConnection(nodea,nodeb)
	for _,obj in pairs(lineConnections) do
		if obj.inputGui == nodea and obj.outputGui == nodeb or obj.inputGui == nodeb and obj.outputGui == nodea then
			return obj
		end
	end
end
function Connectors:UpdateLines()
	for _,obj in pairs(lineConnections) do
		obj:Update();
	end
end
function Connectors:Connect(inputNode,outputNode)
	if inputNode == outputNode then
		return;
	end
	inputNode=inputNode.node;
	outputNode=outputNode.node;
	
	if not inputNode:GetOutput(outputNode.folder) then
		inputNode:CreateOutput(outputNode.folder);
	end
end
function Connectors:StartDrawing(guinode)
	if self.DrawingLine then
		return;
	end
		
	Editor:StopPan();
	
	local DrawingLine = LineTemplate:clone();
	DrawingLine.Visible=false;
	DrawingLine.Parent=Editor.Lines;
		
	self.DrawingFromNode=guinode;
	self.DrawingLine = DrawingLine;
	self.LineDrawer = RunService.Heartbeat:connect(function()
		local Circle = guinode.OutputButton.Circle;
		local Start = Circle.AbsolutePosition + Vector2.new(Circle.AbsoluteSize.x/2,Circle.AbsoluteSize.y/2);
		local End = Vector2.new(PluginMouse.x,PluginMouse.y);
		UpdateLine(nil,DrawingLine,Start,End);
		DrawingLine.Visible=true;
	end)
end
function Connectors:Init(mouse,editor)
	PluginMouse=mouse;
	Editor=editor;
end

function Connectors:StopDrawing()
	if self.DrawingLine then
		if self.LineDrawer then
			self.LineDrawer:disconnect();
		end
		self.DrawingLine:Destroy();
		self.DrawingLine=nil;
		
		
		local found;
		for _,guinode in pairs(Editor.GuiNodes) do
			if guinode.InputOverBool == true then
				found=guinode;
				break;
			end
		end
		if found then
			found.InputOver=false;
			
			if self.DrawingFromNode then
				self:Connect(self.DrawingFromNode,found);
			end
		end
		
		self.DrawingFromNode=nil;
	
	end	
end
function Connectors:Close()
	self:StopDrawing();
	for _,obj in pairs(lineConnections) do
		if obj then
			obj:Dispose();
		end
	end
end

return Connectors;]]></ProtectedString>
