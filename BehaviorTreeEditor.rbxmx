			<Item class="ModuleScript" referent="RBX4BDE2ED13F64421BAD7C5D0A946C51A9">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[-- Add your nodes here, reload the plugin, and they will appear in the editor
-- For parameters: Default is the default value; Input is a text input processor that returns the value for the given text, or nil, and optionally a display text.

local nodes = {
	
	Composite = {
		{
			Name = "Sequence",
			Icon = 4660373175,
			Description = "A Sequence will call every one of its subnodes in order until one node fails or all nodes were called. If one node fails the Sequence will fail too, else it will succeed."
		},
		{
			Name = "Selector",
			Icon = 4660373430,
			Description = "A Selector will call every one of its subnodes in order until one node succeeds, wherein it then succeeds internally. If none succeed, the selector fails."
		},
		{
			Name = "Random",
			Icon = 4660373528,
			Description = "A Random selector calls randomly one node in its list, if it returns running, it will be called again on next run."
		},
		{
			Name = "While",
			Icon = 5866481827,
			Parameters = {
				Count = {Default = 0,Display = "Attempts",Placeholder = "Max Attempts, or ∞ if <= 0.", Input = function(text) local n = tonumber(text) if n then n = math.floor(n) if n > 0 then return n else return 0, "∞" end end end},
			},
			MaxOutputs = 2,
			Description = "Returns failure if the first child fails or max attempts is reached, or returns succeed if the second child succeeds. Otherwise repeats infinitely."
		},
	},
	
	Decorator = {
		{
			Name = "Invert",
			Icon = 4666181063,
			MaxOutputs = 1,
			Description = "Negates the result of its child node. Success becomes failure, failure becomes success."
		},
		{
			Name = "Succeed",
			Icon = 4666182518,
			MaxOutputs = 1,
			Description = "Always returns success, regardless of what child node returns."
		},
		{
			Name = "Fail",
			Icon = 4666183877,
			MaxOutputs = 1,
			Description = "Always returns fail, regardless of what child node returns."
		},
		{
			Name = "Repeat",
			Icon = 5866481827,
			MaxOutputs = 1, 
			Parameters = {
				BreakOnFail = {Default = false},
				Count = {Default = 3, Placeholder = "Num repeats, or ∞ if <= 0.", Input = function(text) local n = tonumber(text) if n then n = math.floor(n) if n > 0 then return n else return 0, "∞" end end end}
			},
			Description = "A Repeat will repeat all its child node actions until its Count parameter is reached, then return success. If the UntilFail parameter is true, and its child fails, it will break repeating and return fail."
		},
	},
	
	Leaf = {
		{
			Name = "Task",
			Icon = 4660400250,
			MaxOutputs = 0,
			Description = "A Task is a node which takes care of all the dirty work in it's run method, which calls success(), fail() or running() in the end. To edit the source of a task click the edit button below the node."
		},
		{
			Name = "External Task",
			Icon = 9257161397,
			MaxOutputs = 0,
			Parameters = {
				Source = {Placeholder = "None", IsObject = true}
			},
			Description = "A Task node that is linked to an External source. To choose a source click on the text box, and then select an object from the explorer."
		},
		{
			Name = "Blackboard Query",
			Icon = 5990243522,
			MaxOutputs = 0,
			Parameters = {
				Board = {Sort = 1, Default = "Entity", Placeholder = "Enter shared board name here", Input = function(text) if not text:match("%S") or text:lower() == "none" or text:lower() == "na" then return "Entity" end return text end},
				Key = {Sort = 2, Default = "", Placeholder = "Enter key", Input = function(text) return text end},
				Value = {Sort = 3,Default = "set", Placeholder = "set/unset/true/false/string", Input = function(text) return text end}
			},
			Description = "Performs a query on an index of a blackboard. This will use the entity's blackboard by default, but you can specify a shared blackboard to use. Checks the value of blackboard[key]; if the Value parameter is \"true\", returns success if the value is true. If the Value parameter is \"false\", returns success if the value is false. If the Value parameter is \"set\", returns success if the value is not nil. If the Value parameter is \"unset\", returns success if the value is nil. if the Value parameter is another string, returns success if the value matches the string. Otherwise returns false."
		},
		{
			Name = "Tree",
			Icon = 4660372929,
			MaxOutputs = 0,
			Parameters = {
				TreeID = {Default = "", Placeholder = "Enter a tree ID string", Input = function(text) return text end}
			},
			Description = "A Tree leaf will call another behavior tree, returning the result passed from the other tree."
		},
	},
	
	Root = {
		Root = {
			Name = "Root",
			Icon = 4660373325,
			MaxOutputs = 1,
			InactiveGradient = script.RootInactiveGradient,
			Description = "The root of the tree. There must be one and only one root for the tree to start from."
		}
	},
	
	Comment = {
		Comment = {
			Name = "Comment",
			Icon = 4660373325,
			MaxOutputs = 0,
			Description = "Used to write comments or descriptions of behavior"
		},
	}
}


local colors = {
	Composite = script.CompositeGradient,
	Decorator = script.DecoratorGradient,
	Leaf = script.LeafGradient,
	Root = script.RootGradient,
	Comment = script.CommentGradient
}


local nodeList = {}
local nodeDictionary = {}
for _, category in pairs({"Composite", "Decorator", "Leaf", "Root", "Comment"}) do
	local list = nodes[category]
	for _, info in pairs(list) do
		info.Type = category
		info.Gradient = colors[category]
		nodeDictionary[info.Name] = info
		table.insert(nodeList, info)
	end
end


return {List = nodeList, Dictionary = nodeDictionary}]]></ProtectedString>
					<string name="ScriptGuid">{0FBFBEBB-3C04-404E-BD45-FB62E65547C0}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
