					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[--!strict
----- Module Settings -----
local DEFAULT_TEMPLATE_SOURCE = script.DefaultTaskTemplate.Source

----- Module / Class / Object Table -----------
local Module = {}

----- Loaded Services -----
local ScriptEditorService = game:GetService("ScriptEditorService")
local StudioService = game:GetService("StudioService")

----- Util / Modules / Shared -----

----- Types / Enums -----

----- Private Variables -----
local plugin = nil

----- Private Methods -----
local function CreateScript(Source: string): ModuleScript?
	local Script = Instance.new("ModuleScript")
	Script.Parent = workspace

	ScriptEditorService:UpdateSourceAsync(Script, function()
		return Source
	end)

	local Success, _ = ScriptEditorService:OpenScriptDocumentAsync(Script)
	if not Success then
		Script:Destroy()
		return
	end

	return Script
end

local function SetTemplate(ScriptSource: string)
	if not ScriptSource then return end

	plugin:SetSetting(`BehaviourTreeEditor-TaskTemplate`, ScriptSource)
	print(`[BehaviourTreeEditor]: Successfully set TaskTemplate source as ->`, {ScriptSource})
end

----- Public Variables -----

----- Public Methods -----
function Module.SetPlugin(obj) -- this must be set before running other functions; "plugin" global does not exist in module script environment even if they are inside a plugin.
	print("Plugin Set!", obj)
	plugin = obj
end

function Module.GetTemplate()
	return plugin:GetSetting("BehaviourTreeEditor-TaskTemplate") or DEFAULT_TEMPLATE_SOURCE
end

function Module.InitButton(Button)
	Button.Click:Connect(function()
		if not Button.Enabled then return end
		
		local ScriptDocument = CreateScript(Module.GetTemplate())
		if not ScriptDocument then return end

		ScriptDocument.Name = `TaskTemplate (BehaviourTreeEditor)`

		Button.Enabled = false
		local CloseConnection
		CloseConnection = ScriptEditorService.TextDocumentDidClose:Connect(function(ClosedScript)
			if ScriptDocument.Parent == nil then -- incase blueprint instance gets destroyed???
				CloseConnection:Disconnect()
				return
			end

			if not string.find(ClosedScript:GetFullName(), ScriptDocument:GetFullName(), 1, true) then -- :GetScript() breaks in team create???
				return
			end

			Button.Enabled = true
			CloseConnection:Disconnect()

			local ScriptSource = ScriptDocument.Source
			ScriptDocument:Destroy()

			SetTemplate(ScriptSource)
		end)
	end)
end

----- Public Object Methods -----

----- Private Object Methods -----

----- Connections -----

----- Initialize -----

return Module]]></ProtectedString>
					<string name="ScriptGuid">{3CC77522-31A4-46B1-9D68-20F5F9A9E534}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
